# file-stats is a gloo-foo *example* — demonstrative code, not a production
# library, so it is not held to the shared 100%-statement-coverage gate (its
# main() and CLI plumbing are illustrative). Swap the coverage gate for one that
# runs the tests without asserting a threshold.
COVER_GATE = cover-example

.PHONY: cover-example
cover-example:
	go test ./...
